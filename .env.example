# NEXUS GOLD — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ห้าม commit ไฟล์ .env ขึ้น Git เด็ดขาด!

# Binance TH API Keys
BINANCE_API_KEY=ใส่_API_KEY_ที่นี่
BINANCE_API_SECRET=ใส่_SECRET_KEY_ที่นี่

# LINE Notify (ถ้าต้องการแจ้งเตือน)
LINE_NOTIFY_TOKEN=

# Telegram Bot (ถ้าต้องการแจ้งเตือน)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
